# ============================================================
# STRIPE – Paiement sécurisé (Carte, Twint, Revolut Pay)
# ============================================================
# Clés disponibles sur : https://dashboard.stripe.com/apikeys

# Clé SECRÈTE (serveur uniquement, ne jamais exposer côté client)
STRIPE_SECRET_KEY=sk_live_...

# Clé PUBLIQUE (côté client, commence par pk_live_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ID du prix créé par le script setup-stripe.mjs (80 CHF)
# Généré automatiquement : node scripts/setup-stripe.mjs
VITE_STRIPE_PRICE_ID=price_...

# Secret webhook Stripe (pour confirmations email automatiques)
# Dashboard Stripe → Développeurs → Webhooks → Ajouter un endpoint
# URL : https://votre-domaine.com/api/webhook
# Événements à écouter : checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# EMAIL (Gmail) – Confirmation après réservation
# ============================================================
EMAIL_USER=votre.email@gmail.com
EMAIL_PASS=mot_de_passe_application_google

# ============================================================
# GEMINI AI – Chat assistant
# ============================================================
GEMINI_API_KEY=
